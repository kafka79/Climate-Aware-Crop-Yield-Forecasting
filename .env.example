# =============================================================
# .env.example — Copy this to .env and fill in your real values
# This file IS committed to version control as documentation.
# The actual .env file is gitignored and never committed.
# =============================================================

# --- SentinelHub (Satellite Imagery) ---
SENTINELHUB_CLIENT_ID=your_sentinelhub_client_id_here
SENTINELHUB_CLIENT_SECRET=your_sentinelhub_client_secret_here
SENTINELHUB_INSTANCE_ID=your_sentinelhub_instance_id_here

# --- UPAg (India Crop Yield Ground Truth) ---
UPAG_API_KEY=your_upag_api_key_here
UPAG_BASE_URL=https://upag.gov.in/api/v1

# --- ISRIC SoilGrids (Soil Properties) ---
ISRIC_API_KEY=your_isric_api_key_here
ISRIC_BASE_URL=https://rest.isric.org/soilgrids/v2.0

# --- ERA5 / Copernicus CDS (Weather Data) ---
CDS_UID=your_cds_uid_here
CDS_API_KEY=your_cds_api_key_here

# --- AI / LLM (Generative Recommendations) ---
GOOGLE_API_KEY=your_google_api_key_here

# --- App Settings ---
STREAMLIT_SERVER_PORT=8501
LOG_LEVEL=INFO
